# AWS region
AWS_DEFAULT_REGION=ap-southeast-1

# Tell the claude CLI subprocess to use Amazon Bedrock (IAM auth, no API key needed)
CLAUDE_CODE_USE_BEDROCK=1

# Secrets Manager ARN for RDS credentials (leave blank until RDS is provisioned)
RDS_SECRET_ARN=

# Database name (overrides the dbname field in the secret if set)
RDS_DB_NAME=
